# --- Agent runtime (app/agent.py) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# Full Vector Search 2.0 collection path (created by infra/terraform).
VECTOR_SEARCH_COLLECTION=projects/your-gcp-project-id/locations/us-central1/collections/rag-vector-search-collection

# --- Data ingestion (make data-ingestion) ---
# Same project/region/collection as above, expressed as the parts
# submit_pipeline.py reads. Keep these consistent with VECTOR_SEARCH_COLLECTION.
PROJECT_ID=your-gcp-project-id
REGION=us-central1
VECTOR_SEARCH_COLLECTION_ID=rag-vector-search-collection
