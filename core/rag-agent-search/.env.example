# GCP project and location
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# Agent Platform Search data store (set from `make setup-infra` outputs:
# data_store_id / data_store_collection)
DATA_STORE_REGION=global
DATA_STORE_COLLECTION=default_collection
DATA_STORE_ID=rag-agent-search-collection_documents
